{
  "name": "on-ai-helper",
  "version": "1.0.0",
  "description": "Discord AI assistant bot for oncompute.ai support",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "deploy": "bun run src/bot/deploy-commands.ts",
    "ai:init": "bun run src/scripts/init-vector-store.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "discord.js": "^14.16.0",
    "ioredis": "^5.9.2",
    "node-html-markdown": "^1.3.0",
    "openai": "^4.70.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
